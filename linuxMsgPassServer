
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <mqueue.h>
#include <errno.h>
 

#define SERVER_QUEUE    "/square_server"
#define CLIENT_QUEUE    "/square_client"
#define MAX_MSG_SIZE    64
#define QUEUE_PERMS     0660
 

typedef struct {
    int  number;   /* client sends this */
    int  result;   /* server fills this in the reply */
} Message;
 
int main(void)
{
    mqd_t      server_q, client_q;
    struct mq_attr  attr;
    Message    msg;
    ssize_t    bytes;
 
  
    attr.mq_flags   = 0;
    attr.mq_maxmsg  = 10;
    attr.mq_msgsize = sizeof(Message);
    attr.mq_curmsgs = 0;
 
  
    server_q = mq_open(SERVER_QUEUE,
                       O_CREAT | O_RDONLY,
                       QUEUE_PERMS,
                       &attr);
    if (server_q == (mqd_t)-1) {
        perror("mq_open server queue failed");
        exit(EXIT_FAILURE);
    }
 
    printf("[Server] Ready. Listening on queue: %s\n", SERVER_QUEUE);
    printf("[Server] Waiting for client requests...\n\n");
 
   
    while (1) {
       
        bytes = mq_receive(server_q, (char *)&msg, sizeof(Message), NULL);
        if (bytes < 0) {
            perror("mq_receive failed");
            break;
        }
 
        printf("[Server] Received number: %d\n", msg.number);
 
       
        if (msg.number == -1) {
            printf("[Server] Shutdown signal received. Exiting.\n");
            break;
        }
 
      
        msg.result = msg.number * msg.number;
        printf("[Server] Sending back square: %d\n\n", msg.result);
 
     
        client_q = mq_open(CLIENT_QUEUE, O_WRONLY);
        if (client_q == (mqd_t)-1) {
            perror("mq_open client reply queue failed");
            continue;   /* skip this reply, keep running */
        }
 
        if (mq_send(client_q, (char *)&msg, sizeof(Message), 0) < 0) {
            perror("mq_send reply failed");
        }
 
        mq_close(client_q);
    }
 
   
    mq_close(server_q);
    mq_unlink(SERVER_QUEUE);
 
    printf("[Server] Cleaned up queue. Goodbye.\n");
    return 0;
}
